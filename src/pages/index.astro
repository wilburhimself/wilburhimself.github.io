---
import BlogLayout from '../layouts/BlogLayout.astro';
---

<BlogLayout title="Wilbur Suero - Staff Backend Engineer" description="I help engineering teams build backend systems that scale without becoming harder to operate. Specializing in high-performance Rails, distributed systems, and production AI.">
  <div class="main py-12">
    <div class="profile">
      <div class="profile_inner">
        <h1>Wilbur Suero</h1>
        
        <p class="max-w-xl mx-auto text-lg font-semibold leading-snug" style="color: var(--primary);">
          I build backend systems that scale without becoming harder to operate.
        </p>
        
        <p class="max-w-xl mx-auto text-secondary text-sm">
          Specializing in high-performance Rails, distributed systems, and production AI infrastructure. <strong>No magic, just systems.</strong> I believe the best engineering decisions are those that eliminate operational complexity and remove layers of magic from software.
        </p>

        <!-- Selected Achievements -->
        <div class="impact-section">
          <h2>Selected Achievements</h2>
          <ul class="impact-list">
            <li class="impact-item">
              <span class="impact-icon">&rarr;</span>
              <span><strong>Reduced LLM API latency by 60%</strong> and minimized token overhead by designing strategic caching and early-exit workflows.</span>
            </li>
            <li class="impact-item">
              <span class="impact-icon">&rarr;</span>
              <span><strong>Architected <a href="https://prestacrm.com" target="_blank" rel="noopener noreferrer">PrestaCRM</a></strong>, a specialized credit CRM managing over RD$10,000,000 in active portfolios and cutting average delinquency by 18%.</span>
            </li>
            <li class="impact-item">
              <span class="impact-icon">&rarr;</span>
              <span><strong>Built production AI infrastructure</strong> serving 50K+ daily interactions under strict reliability and throughput constraints.</span>
            </li>
            <li class="impact-item">
              <span class="impact-icon">&rarr;</span>
              <span><strong>Designed distributed event-driven pipelines</strong> processing over 100K daily events with zero data loss.</span>
            </li>
            <li class="impact-item">
              <span class="impact-icon">&rarr;</span>
              <span><strong>Created open-source libraries</strong> (<a href="https://github.com/wilburhimself/promptly" target="_blank" rel="noopener noreferrer">Promptly</a>, <a href="https://github.com/wilburhimself/outbox_rails" target="_blank" rel="noopener noreferrer">Outbox Rails</a>) adopted by the Ruby on Rails developer community.</span>
            </li>
          </ul>
        </div>

        <!-- Featured Projects -->
        <div class="featured-projects">
          <h2>Featured Projects</h2>
          <div class="featured-projects-grid">
            <div class="featured-project-card">
              <div>
                <h3 class="featured-project-title">PrestaCRM</h3>
                <p class="featured-project-desc">
                  A vertical B2B SaaS platform for credit and debt collection. Featuring a French amortization engine, an immutable double-entry ledger, automated credit risk scoring, and WhatsApp API alerts.
                </p>
                <div class="featured-project-tech">
                  <span class="featured-project-badge">Next.js</span>
                  <span class="featured-project-badge">TypeScript</span>
                  <span class="featured-project-badge">PostgreSQL</span>
                  <span class="featured-project-badge">WhatsApp API</span>
                </div>
              </div>
              <div class="featured-project-links">
                <a class="featured-project-link" href="https://prestacrm.com" target="_blank" rel="noopener noreferrer">Live Site &rarr;</a>
                <a class="featured-project-link" href="/projects/">Case Study &rarr;</a>
              </div>
            </div>

            <div class="featured-project-card">
              <div>
                <h3 class="featured-project-title">Promptly</h3>
                <p class="featured-project-desc">
                  A centralized prompt management engine for Ruby on Rails. Introduces versioning, schema validation, localization, and ERB/Liquid templates to decoupling prompts from codebase deployments.
                </p>
                <div class="featured-project-tech">
                  <span class="featured-project-badge">Ruby</span>
                  <span class="featured-project-badge">Rails</span>
                  <span class="featured-project-badge">Liquid</span>
                  <span class="featured-project-badge">RSpec</span>
                </div>
              </div>
              <div class="featured-project-links">
                <a class="featured-project-link" href="https://github.com/wilburhimself/promptly" target="_blank" rel="noopener noreferrer">GitHub &rarr;</a>
                <a class="featured-project-link" href="/blog/30-writing-maintainable-ai-ai-prompts-with-promptly/">Blog Post &rarr;</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Featured Writing -->
        <div class="featured-writing">
          <h2>Featured Writing</h2>
          
          <div class="featured-article-card">
            <h3 class="featured-article-title">
              <a href="/blog/54-your-codebase-already-taught-you-how-to-start-a-business/" style="color: inherit; text-decoration: none;">
                Every Business Mistake Maps to a Bug You've Already Fixed
              </a>
            </h3>
            <p class="featured-article-excerpt">
              You don't need new mental models to start a business. You need to recognize the ones your codebase already gave you, and the one place where they'll betray you.
            </p>
            <a class="featured-article-link" href="/blog/54-your-codebase-already-taught-you-how-to-start-a-business/">
              Read Article &rarr;
            </a>
          </div>

          <ul class="other-writings-list">
            <li class="other-writing-item">
              <span class="other-writing-category">Strategy</span>
              <a class="other-writing-link" href="/blog/57-why-most-technical-migrations-fail/">
                Why Most Technical Migrations Fail
              </a>
            </li>
            <li class="other-writing-item">
              <span class="other-writing-category">Architecture</span>
              <a class="other-writing-link" href="/blog/52-system-boundaries-become-visible-only-when-crossed-incorrectly/">
                System Boundaries Become Visible Only When Crossed Incorrectly
              </a>
            </li>
            <li class="other-writing-item">
              <span class="other-writing-category">Performance</span>
              <a class="other-writing-link" href="/blog/53-set-based-updates-in-rails/">
                Set-Based Updates in Rails: 4 Hours to 8 Seconds
              </a>
            </li>
          </ul>
        </div>

        <!-- Profile Action Buttons -->
        <div class="buttons">
          <a class="button" href="/about/" title="About Me">About</a>
          <a class="button" href="/projects/" title="My Projects">Projects</a>
          <a class="button" href="/blog/" title="My Blog">Blog</a>
          <a class="button" href="https://calendly.com/suerowilbur/30min" target="_blank" rel="noopener noreferrer" title="Schedule Consultation">Consultation</a>
        </div>

        <!-- Social Icons -->
        <div class="social-icons">
          <!-- LinkedIn -->
          <a href="https://linkedin.com/in/wilbursuero" target="_blank" rel="noopener noreferrer" title="LinkedIn" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
              <rect x="2" y="9" width="4" height="12"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
          </a>

          <!-- GitHub -->
          <a href="https://github.com/wilburhimself" target="_blank" rel="noopener noreferrer" title="GitHub" aria-label="GitHub">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
            </svg>
          </a>

          <!-- Email -->
          <a href="mailto:suerowilbur@gmail.com" title="Email" aria-label="Email">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </a>

          <!-- Calendly (Calendar Icon) -->
          <a href="https://calendly.com/suerowilbur/30min" target="_blank" rel="noopener noreferrer" title="Schedule Call" aria-label="Schedule Call">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</BlogLayout>
