---
import { getCollection } from 'astro:content';
import BlogLayout from '../layouts/BlogLayout.astro';

const allPosts = await getCollection('blog');
const nonDraftPosts = allPosts.filter((post) => !post.data.draft);

// Find the featured post or fallback to the most recent one
const featuredPost = nonDraftPosts.find((post) => post.data.featured) || 
  [...nonDraftPosts].sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())[0];

// Fetch the 3 latest articles excluding the featured post
const latestArticles = nonDraftPosts
  .filter((post) => post.id !== featuredPost.id)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

