---
import BlogLayout from '../layouts/BlogLayout.astro';
---

<BlogLayout title="Wilbur Suero - Staff Backend Engineer" description="Staff Backend Engineer specializing in Distributed Systems & Applied AI. No Magic, Just Systems.">
  <div class="main">
    <div class="profile">
      <div class="profile_inner">
        <h1>Wilbur Suero</h1>
        <p>
          Staff Backend Engineer &bull; <strong>No Magic, Just Systems</strong>
        </p>
        <p class="max-w-md mx-auto text-secondary text-sm">
          I help engineering teams simplify distributed systems, optimize database performance, and ship AI features that survive production. Currently designing high-throughput systems at <strong>Puzzle</strong>.
        </p>

        <!-- Key Outcomes & Achievements -->
        <div class="achievements-section">
          <h2>Key Achievements</h2>
          <div class="achievements-grid">
            <div class="achievement-card">
              <div class="achievement-stat">50K+</div>
              <div class="achievement-label">Daily Conversations</div>
              <p class="achievement-desc">Scaled production LLM pipelines handling high-throughput conversational AI and classification.</p>
            </div>
            <div class="achievement-card">
              <div class="achievement-stat">60%</div>
              <div class="achievement-label">Latency Reduction</div>
              <p class="achievement-desc">Optimized database systems, caching strategies, and API latency for distributed services.</p>
            </div>
            <div class="achievement-card">
              <div class="achievement-stat">10+ Yrs</div>
              <div class="achievement-label">Backend Systems</div>
              <p class="achievement-desc">Engineering robust Ruby on Rails, Elixir, and SQL architectures designed for longevity.</p>
            </div>
            <div class="achievement-card">
              <div class="achievement-stat">95%</div>
              <div class="achievement-label">Test Coverage</div>
              <p class="achievement-desc">Mentored developers in test-driven development (TDD) and clean code, cutting production defects.</p>
            </div>
          </div>
        </div>

        <!-- Profile Action Buttons -->
        <div class="buttons">
          <a class="button" href="/about/" title="About Me">About</a>
          <a class="button" href="/projects/" title="My Projects">Projects</a>
          <a class="button" href="/blog/" title="My Blog">Blog</a>
          <a class="button" href="https://calendly.com/suerowilbur/30min" target="_blank" rel="noopener noreferrer" title="Schedule Consultation">Consultation</a>
        </div>

        <!-- Social Icons -->
        <div class="social-icons">
          <!-- LinkedIn -->
          <a href="https://linkedin.com/in/wilbursuero" target="_blank" rel="noopener noreferrer" title="LinkedIn" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
              <rect x="2" y="9" width="4" height="12"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
          </a>

          <!-- GitHub -->
          <a href="https://github.com/wilburhimself" target="_blank" rel="noopener noreferrer" title="GitHub" aria-label="GitHub">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
            </svg>
          </a>

          <!-- Email -->
          <a href="mailto:suerowilbur@gmail.com" title="Email" aria-label="Email">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </a>

          <!-- Calendly (Calendar Icon) -->
          <a href="https://calendly.com/suerowilbur/30min" target="_blank" rel="noopener noreferrer" title="Schedule Call" aria-label="Schedule Call">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</BlogLayout>
