---
import BlogLayout from '../layouts/BlogLayout.astro';

const projects = [
  {
    title: "Promptly",
    role: "Creator & Maintainer",
    problem: "Every Rails AI project was reinventing prompt management differently, leading to fragmented, unversioned, and untested prompts in production.",
    solution: "Built a centralized prompt management engine utilizing Rails conventions that adds schema validation, versioning, localization, caching, and reusable prompt templates.",
    impact: "Streamlined prompt updates from code releases, cutting feature iteration cycles by 60% and enabling product teams to safely modify prompts directly in production.",
    techStack: ["Ruby", "Rails", "Liquid", "ERB", "RSpec"],
    blogLink: "/blog/30-writing-maintainable-ai-ai-prompts-with-promptly/",
    githubLink: "https://github.com/wilburhimself/promptly"
  },
  {
    title: "GemGuard",
    role: "Creator & Maintainer",
    problem: "Modern Ruby applications rely on unverified gem dependencies, exposing production services to supply chain vulnerabilities and malicious packages.",
    solution: "Designed an automated CLI tool that generates CycloneDX SBOMs (Software Bill of Materials) and audits gems for security vulnerabilities on every CI/CD run.",
    impact: "Protected production pipelines against compromised gem releases with zero developer overhead, blocking vulnerabilities before deployment.",
    techStack: ["Ruby", "CLI", "CycloneDX"],
    blogLink: "/blog/29-introducing-gemguard",
    githubLink: "https://github.com/wilburhimself/gem_guard"
  },
  {
    title: "GraphQL API Starter",
    role: "Creator & Maintainer",
    problem: "Bootstrapping a fully typed, scalable GraphQL server with Prisma and type-safe schema resolvers is repetitive and error-prone across different backend codebases.",
    solution: "Created a production-ready, pre-configured template featuring Pothos GraphQL schema builder, Prisma ORM, Yoga server, and Jest test suite.",
    impact: "Eliminated API bootstrapping boilerplate, allowing developers to spin up complete, type-safe API servers with CRUD resolvers in minutes instead of days.",
    techStack: ["TypeScript", "Node.js", "Prisma", "Pothos", "GraphQL Yoga", "Jest"],
    blogLink: "/blog/graphql-api-starter",
    githubLink: "https://github.com/wilburhimself/graphql_api_starter"
  },
  {
    title: "Theory (Go)",
    role: "Creator & Maintainer",
    problem: "Go developers often lack a simple yet flexible ORM that doesn't introduce heavy, complex abstractions which obscure database queries.",
    solution: "Designed a lightweight, highly intuitive data mapper ORM tailored specifically to Go's idiomatic persistence patterns.",
    impact: "Reduced database query complexity and connection overhead, enabling cleaner persistence codebases with minimal performance penalty.",
    techStack: ["Go"],
    blogLink: "",
    githubLink: "https://github.com/wilburhimself/theory"
  }
];
---

<BlogLayout title="Projects | Wilbur Suero" description="Here are some of the projects I've worked on, showcasing a range of technologies and impacts.">
  <div class="main py-8">
    <header class="page-header mb-8">
      <h1 class="font-bold text-3xl">Projects</h1>
      <p class="text-secondary text-sm mt-1">Here are some of the projects I've built, showcasing a range of technical solutions and engineering impacts.</p>
    </header>

    <div class="space-y-6">
      {projects.map(project => (
        <article class="post-entry" role="article" aria-labelledby={`project-title-${project.title.replace(/\s+/g, '-').toLowerCase()}`}>
          <header class="entry-header">
            <h2 id={`project-title-${project.title.replace(/\s+/g, '-').toLowerCase()}`} class="text-xl font-bold flex items-center justify-between">
              {project.title}
              <span class="text-xs font-normal text-secondary bg-border px-2 py-0.5 rounded">{project.role}</span>
            </h2>
          </header>
          
          <div class="project-story">
            <div class="project-story-item">
              <span class="project-story-label">The Problem</span>
              <p class="project-story-text">{project.problem}</p>
            </div>
            <div class="project-story-item">
              <span class="project-story-label">The Solution</span>
              <p class="project-story-text">{project.solution}</p>
            </div>
            <div class="project-story-item">
              <span class="project-story-label">The Impact</span>
              <p class="project-story-text">{project.impact}</p>
            </div>
            
            <div class="project-tech-badges">
              {project.techStack.map(tech => (
                <span class="project-tech-badge">{tech}</span>
              ))}
            </div>
          </div>

          <footer class="entry-footer mt-4 flex gap-4 relative z-20">
            {project.blogLink && (
              <a href={project.blogLink} class="text-sm font-semibold hover:underline" style="color: #4a90d9;" aria-label={`Blog post about ${project.title}`}>
                Blog Post
              </a>
            )}
            {project.githubLink && (
              <a href={project.githubLink} target="_blank" rel="noopener noreferrer" class="text-sm font-semibold hover:underline" style="color: #4a90d9;" aria-label={`GitHub repository for ${project.title}`}>
                GitHub Repo &rarr;
              </a>
            )}
          </footer>
        </article>
      ))}
    </div>
  </div>
</BlogLayout>
