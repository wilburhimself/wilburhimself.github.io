---
import { getCollection } from 'astro:content';
import BlogLayout from '../../../layouts/BlogLayout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const publishedPosts = allPosts.filter((post) => !post.data.draft);
  const uniqueTags = [...new Set(publishedPosts.map((post) => post.data.tags || []).flat())];

  return uniqueTags.map((tag) => {
    const filteredPosts = publishedPosts.filter((post) => post.data.tags?.includes(tag));
    return {
      params: { tag },
      props: { posts: filteredPosts },
    };
  });
}

const { tag } = Astro.params;
const { posts } = Astro.props;
const sortedPosts = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BlogLayout title={`Posts tagged with ${tag}`}>
  <div class="main py-8">
    <header class="page-header mb-8">
      <h1 class="font-bold text-3xl">Posts tagged with <span style="color: #4a90d9;">#{tag}</span></h1>
    </header>
    
    <div class="articles">
      {sortedPosts.map((post) => {
        const wordCount = post.body ? post.body.split(/\s+/).length : 0;
        const readingTime = Math.max(1, Math.ceil(wordCount / 200));

        return (
          <article class="post-entry">
            <header class="entry-header">
              <h2>{post.data.title}</h2>
            </header>
            <div class="entry-content">
              <p>{post.data.excerpt || 'Read more...'}</p>
            </div>
            <footer class="entry-footer">
              <span>{post.data.date}</span>&nbsp;&middot;&nbsp;
              <span>{readingTime} min read</span>
              {post.data.tags && post.data.tags.length > 0 && (
                <span>&nbsp;&middot;&nbsp;Tags: {post.data.tags.map(t => `#${t}`).join(' ')}</span>
              )}
            </footer>
            <a class="entry-link" aria-label={`post link to ${post.data.title}`} href={`/blog/${post.slug}/`}></a>
          </article>
        );
      })}
    </div>
    
    <footer class="mt-12 pt-6 border-t border-border">
      <a href="/blog/" class="text-sm text-secondary hover:text-primary transition-colors">
        &larr; Back to Articles
      </a>
    </footer>
  </div>
</BlogLayout>
