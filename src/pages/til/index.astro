---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

const allTils = (await getCollection('til')).sort((a, b) => {
  const dateA = new Date(a.data.date);
  const dateB = new Date(b.data.date);
  return dateB.getTime() - dateA.getTime();
});

const tilsWithContent = await Promise.all(
  allTils.map(async (til) => {
    const { Content } = await til.render();
    return { til, Content };
  })
);
---

<BlogLayout title="Microblog" description="Quick thoughts, learnings, and discoveries.">
  <div class="main py-8">
    <header class="page-header mb-8">
      <h1 class="font-bold text-3xl">Microblog</h1>
      <p class="text-secondary text-sm mt-1">Quick thoughts, learnings, and discoveries.</p>
    </header>

    <div class="space-y-6">
      {
        tilsWithContent.map(({ til, Content }) => (
          <article class="post-entry">
            <header class="entry-header">
              <h2 class="text-lg font-bold">
                <a href={`/til/${til.slug}/`} class="hover:underline">
                  {til.data.title}
                </a>
              </h2>
            </header>
            <div class="post-content entry-content mt-2 text-sm max-w-none">
              <Content />
            </div>
            <footer class="entry-footer mt-4">
              <span class="font-mono text-xs">{til.data.date}</span>
              {til.data.tags && (
                <span class="text-xs text-secondary ml-2">
                  {til.data.tags.map(tag => `#${tag}`).join(' ')}
                </span>
              )}
            </footer>
          </article>
        ))
      }
    </div>
  </div>
</BlogLayout>
