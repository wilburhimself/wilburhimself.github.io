---
const { title, description, image } = Astro.props;
import '../styles/global.css';
import Header from '../components/Header.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-EJ3RHGXYJM"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-EJ3RHGXYJM');
    </script>

    <!-- Flicker-free Theme Initialization -->
    <script is:inline>
      (function() {
        const theme = localStorage.getItem("pref-theme") || 
                      (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title ? `${title} - Wilbur Suero` : "Wilbur Suero"}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="google-site-verification" content="acCq17rKpmEhikjDHZPb3HqFlomtEcqh9ueRvLzOqx8" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title || "Wilbur Suero"} />
    <meta property="og:description" content={description || "Staff Backend Engineer specializing in high-performance Rails, distributed architecture, and production AI."} />
    {image && <meta property="og:image" content={new URL(image, Astro.url)} />}

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title || "Wilbur Suero"} />
    <meta property="twitter:description" content={description || "Staff Backend Engineer specializing in high-performance Rails, distributed architecture, and production AI."} />
    {image && <meta property="twitter:image" content={new URL(image, Astro.url)} />}
  </head>
  <body>
    <Header currentPath={Astro.url.pathname} />

    <slot />

    <footer class="footer">
      <span>&copy; {new Date().getFullYear()} <a href="/">Wilbur Suero</a></span>
      <span>&middot; No magic, just systems.</span>
      <div class="mt-3 flex justify-center gap-3 opacity-75 text-xs">
        <a href="https://calendly.com/suerowilbur/30min" target="_blank" rel="noopener noreferrer">Schedule consultation</a> &middot;
        <a href="mailto:suerowilbur@gmail.com">Email</a> &middot;
        <a href="https://github.com/wilburhimself" target="_blank" rel="noopener noreferrer">GitHub</a> &middot;
        <a href="https://linkedin.com/in/wilbursuero" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
    </footer>
  </body>
</html>

<script>
  import '../scripts/mermaid-init.js';
</script>
