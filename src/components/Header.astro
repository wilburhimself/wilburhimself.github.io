---
const { currentPath } = Astro.props;

// Determine active state for links
const isActive = (path) => {
  if (path === '/blog') {
    return currentPath === '/blog' || currentPath?.startsWith('/blog/');
  }
  if (path === '/til') {
    return currentPath === '/til' || currentPath?.startsWith('/til/');
  }
  return currentPath === path || currentPath === `${path}/`;
};
---

<header class="header">
  <nav class="header-nav">
    <div class="logo">
      <a href="/" title="Wilbur Suero" accesskey="h">Wilbur Suero</a>
      <div class="logo-switches">
        <button id="theme-toggle" accesskey="t" title="(Alt + T)" aria-label="Toggle Theme">
          <svg id="moon-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="18" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
               stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
          <svg id="sun-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="18" viewBox="0 0 24 24"
               fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
               stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="1" x2="12" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="23"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="1" y1="12" x2="3" y2="12"></line>
            <line x1="21" y1="12" x2="23" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line x1="18.36" y1="4.22" x2="19.78" y2="5.64"></line>
          </svg>
        </button>
      </div>
    </div>
    <ul class="menu">
      <li class={isActive('/about') ? 'active' : ''}>
        <a href="/about/" title="About">About</a>
      </li>
      <li class={isActive('/projects') ? 'active' : ''}>
        <a href="/projects/" title="Projects">Projects</a>
      </li>
      <li class={isActive('/blog') ? 'active' : ''}>
        <a href="/blog/" title="Blog">Blog</a>
      </li>
      <li class={isActive('/til') ? 'active' : ''}>
        <a href="/til/" title="Microblog">Microblog</a>
      </li>
    </ul>
  </nav>
</header>

<style>
  /* Localized overrides to ensure Sun/Moon icons toggle perfectly */
  #theme-toggle {
    background: none;
    border: 0;
    cursor: pointer;
    padding: 0 0.4rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
  }

  #theme-toggle svg {
    display: none;
    width: 24px;
    height: 18px;
    stroke-width: 2px;
  }

  /* Inline Javascript for toggling and persisting */
  :global(html[data-theme='dark']) #theme-toggle #sun-icon {
    display: block;
  }
  :global(html[data-theme='dark']) #theme-toggle #moon-icon {
    display: none;
  }
  :global(html:not([data-theme='dark'])) #theme-toggle #sun-icon {
    display: none;
  }
  :global(html:not([data-theme='dark'])) #theme-toggle #moon-icon {
    display: block;
  }
</style>

<script is:inline>
  (function() {
    const toggleButton = document.getElementById('theme-toggle');
    if (toggleButton) {
      toggleButton.addEventListener('click', () => {
        const root = document.documentElement;
        const currentTheme = root.getAttribute('data-theme') || 
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        const nextTheme = currentTheme === 'dark' ? 'light' : 'dark';
        
        root.setAttribute('data-theme', nextTheme);
        localStorage.setItem('pref-theme', nextTheme);
      });
    }
  })();
</script>
